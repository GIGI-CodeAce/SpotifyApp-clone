{
  "compilerOptions": {
    "jsx": "react-jsx", // or "preserve" or "react"
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "Node",
    "target": "es6",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}